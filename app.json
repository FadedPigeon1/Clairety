{
  "expo": {
    "name": "Clairety",
    "slug": "clairety",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "clairety",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.clairety.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Clairety needs camera access to scan and identify your clothing items."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#020617"
      },
      "package": "com.clairety.app",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Clairety needs camera access to scan and identify your clothing items."
        }
      ],
      "expo-asset",
      "expo-font"
    ]
  }
}
