# Clairety Frontend Environment Variables — Template
# Rename this file to `.env` and fill in the values before running the app.

# Replace this with your computer's local IP address so your phone can reach it.
# Find it on Mac with: ifconfig | grep "inet " | grep -v 127.0.0.1
API_BASE_URL=http://10.0.0.139:3000/api

# Future: Add client-side API keys here
# GOOGLE_VISION_API_KEY=your_google_key
# OPENAI_API_KEY=your_openai_key
